let appIconData = null;
document.getElementById('iconUpload')?.addEventListener('change', async () => {
  const file = document.getElementById('iconUpload').files[0]; if (!file) return;
  const reader = new FileReader(); reader.onload = e => { appIconData = e.target.result; const preview = document.getElementById('iconPreview'); if (preview) preview.innerHTML = `<img src="${appIconData}" style="width:48px;height:48px;border-radius:8px;">`; }; reader.readAsDataURL(file);
});
document.querySelectorAll('.export-btn').forEach(btn => btn.addEventListener('click', async () => {
  const platform = btn.dataset.platform; const status = document.getElementById('exportStatus'); if (status) status.textContent = '打包中...';
  try {
    const zip = await generateExportZip(platform); const content = await zip.generateAsync({type:'blob'});
    if (window.Android) { const reader = new FileReader(); reader.onload = () => window.Android.saveFile(reader.result, `lumilo-${platform}.zip`); reader.readAsDataURL(content); }
    else { saveAs(content, `lumilo-${platform}.zip`); }
    if (status) status.textContent = '导出成功！';
  } catch(e) { if (status) status.textContent = '失败: '+e.message; }
}));

async function generateExportZip(platform) {
  const zip = new JSZip();
  const playerHTML = await generateOfflinePlayerHTML();
  zip.file("index.html", playerHTML);
  if (platform === 'windows') {
    const pkg = { name:"lumilo-game", main:"index.html", window:{ title:"织光", fullscreen:false, resizable:true } };
    if (appIconData) pkg.window.icon = "icon.png";
    zip.file("package.json", JSON.stringify(pkg, null, 2));
    zip.file("build.bat", `@echo off\nif not exist nw\\nw.exe (curl -L -o nw.zip https://dl.nwjs.io/v0.77.0/nwjs-sdk-v0.77.0-win-x64.zip && tar -xf nw.zip && ren nwjs-sdk-v0.77.0-win-x64 nw)\ncopy /b nw\\nw.exe + index.html game.exe\necho Done`);
  } else if (platform === 'android') {
    let cfg = `<?xml version='1.0' encoding='utf-8'?>\n<widget id="com.lumilo.game" version="1.0.0" xmlns="http://www.w3.org/ns/widgets">\n    <name>织光</name>\n    <content src="index.html" />\n    <allow-intent href="*" />\n`;
    if (appIconData) cfg += `    <icon src="icon.png" />\n`;
    cfg += `</widget>`;
    zip.file("config.xml", cfg);
    zip.file("build.bat", `@echo off\necho Install Node.js and Cordova first.\ncall cordova create temp com.lumilo.game Lumilo\ncopy index.html temp\\www\\\ncd temp\ncall cordova platform add android\ncall cordova build android\necho APK at temp\\platforms\\android\\app\\build\\outputs\\apk\\debug`);
  }
  if (appIconData && platform !== 'web') zip.file("icon.png", dataURItoBlob(appIconData));
  return zip;
}

