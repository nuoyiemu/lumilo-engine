// 游戏引擎
class GameState {
  constructor() { this.variables = {}; this.currentNodeId = null; this.sceneState = { background: null, sprites: [] }; this.filter = 'none'; this.lighting = { vignette:0, glow:0, sun:0, cinematic:0 }; }
  setVar(k,v) { this.variables[k] = v; }
  getVar(k) { return this.variables[k] || 0; }
  addVar(k,d) { this.setVar(k, this.getVar(k) + d); }
  save(slot) {
    let thumbnail = '';
    try { const sceneEl = document.getElementById('scene'); const canvas = document.createElement('canvas'); canvas.width = sceneEl.offsetWidth; canvas.height = sceneEl.offsetHeight; const ctx = canvas.getContext('2d'); ctx.drawImage(sceneEl, 0, 0, canvas.width, canvas.height); thumbnail = canvas.toDataURL('image/jpeg', 0.5); } catch(e) {}
    localStorage.setItem(`gal_save_${slot}`, JSON.stringify({ variables: this.variables, currentNodeId: this.currentNodeId, sceneState: this.sceneState, filter: this.filter, lighting: this.lighting, autoMode, skipMode, thumbnail, timestamp: Date.now() }));
  }
  load(slot) {
    const raw = localStorage.getItem(`gal_save_${slot}`);
    if (!raw) return false;
    try {
      const data = JSON.parse(raw);
      this.variables = data.variables; this.currentNodeId = data.currentNodeId;
      this.sceneState = data.sceneState || { background:null, sprites:[] };
      this.filter = data.filter || 'none'; this.lighting = data.lighting || { vignette:0, glow:0, sun:0, cinematic:0 };
      setAutoMode(data.autoMode || false); setSkipMode(data.skipMode || false);
      return true;
    } catch(e) { return false; }
  }
}

class UIManager {
  constructor() {
    this.scene = document.getElementById('scene'); this.speaker = document.getElementById('speaker');
    this.textEl = document.getElementById('text'); this.choicesEl = document.getElementById('choices');
    this.dialogPanel = document.getElementById('dialogPanel'); this.gameEnded = false;
    this.typewriterTimer = null; this.autoTimer = null; this.waitingForInput = false; this.cursorEl = null;
  }
  clearAutoTimer() { if (this.autoTimer) { clearTimeout(this.autoTimer); this.autoTimer = null; } }
  stopTypewriter() { if (this.typewriterTimer) { clearTimeout(this.typewriterTimer); this.typewriterTimer = null; } }

  async setBackground(bgId) {
    if (!bgId) { this.scene.style.backgroundImage = ''; return; }
    const bg = await getFromStore('backgrounds', bgId);
    if (bg) {
      if (settings.bgTransition) {
        this.scene.style.transition = 'opacity 0.5s';
        this.scene.style.opacity = '0';
        setTimeout(() => { this.scene.style.backgroundImage = `url(${bg.data})`; this.scene.style.opacity = '1'; }, 500);
      } else {
        this.scene.style.backgroundImage = `url(${bg.data})`;
      }
    }
  }

  async showCharacter(charName, expression, position='center') {
    const oldSprites = this.scene.querySelectorAll(`.sprite.${position}`);
    if (settings.spriteTransition && oldSprites.length) {
      oldSprites.forEach(el => { el.style.transition = 'opacity 0.4s'; el.style.opacity = '0'; el.addEventListener('transitionend', () => el.remove()); });
    } else oldSprites.forEach(el => el.remove());

    if (!charName || !expression) return;
    const sprite = await getFromStore('sprites', `${charName}/${expression}`);
    if (!sprite) return;
    const img = document.createElement('img'); img.className = `sprite ${position}`; img.src = sprite.data; img.alt = charName;
    if (settings.spriteTransition) { img.style.opacity = '0'; this.scene.appendChild(img); requestAnimationFrame(() => { img.style.transition = 'opacity 0.4s'; img.style.opacity = '1'; }); }
    else this.scene.appendChild(img);
  }

  clearAllSprites() { this.scene.querySelectorAll('.sprite').forEach(el => el.remove()); }

  showDialogue(speaker, text, callback) {
    if (this.gameEnded || this.waitingForInput) return;
    this.waitingForInput = true; this.choicesEl.innerHTML = ''; this.stopTypewriter(); this.clearAutoTimer();
    this.speaker.textContent = speaker || '';
    if (this.cursorEl) this.cursorEl.remove();

    if (skipMode) {
      const skipAll = settings.skipAll;
      const nodeId = gameState.currentNodeId;
      if (skipAll || readNodes.has(nodeId)) {
        this.textEl.textContent = text; readNodes.add(nodeId); this.waitingForInput = false; if (callback) callback(); return;
      }
    }

    this.textEl.textContent = '';
    if (settings.showCursor) { this.cursorEl = document.createElement('span'); this.cursorEl.className = 'text-cursor'; this.textEl.appendChild(this.cursorEl); }

    let index = 0; const speed = settings.textSpeed;
    const type = () => {
      if (index < text.length) {
        this.textEl.insertBefore(document.createTextNode(text.charAt(index)), this.cursorEl || null);
        index++; this.typewriterTimer = setTimeout(type, speed);
      } else {
        if (this.cursorEl) this.cursorEl.remove();
        this.typewriterTimer = null; readNodes.add(gameState.currentNodeId);
        if (autoMode) {
          this.autoTimer = setTimeout(() => { this.autoTimer = null; this.waitingForInput = false; if (callback) callback(); }, settings.autoDelay * 1000);
        } else { this.waitingForInput = false; }
      }
    };
    type();

    const advance = () => {
      if (this.typewriterTimer) { clearTimeout(this.typewriterTimer); this.textEl.textContent = text; if (this.cursorEl) this.cursorEl.remove(); this.typewriterTimer = null; readNodes.add(gameState.currentNodeId); this.clearAutoTimer(); this.waitingForInput = false; return; }
      this.clearAutoTimer(); this.dialogPanel.removeEventListener('click', advance); this.scene.removeEventListener('click', sceneAdvance); this.waitingForInput = false;
      if (callback) callback();
    };
    const sceneAdvance = () => advance();
    this.dialogPanel.addEventListener('click', advance); this.scene.addEventListener('click', sceneAdvance);
  }

  advance() { if (this.waitingForInput && !this.typewriterTimer) this.dialogPanel.click(); else if (this.typewriterTimer) this.dialogPanel.click(); }

  showChoices(choices, onSelect) {
    setAutoMode(false); setSkipMode(false);
    if (this.gameEnded) return;
    this.choicesEl.innerHTML = '';
    choices.forEach(c => {
      const btn = document.createElement('button'); btn.className = 'choice-btn'; btn.textContent = c.text;
      btn.addEventListener('click', (e) => { e.stopPropagation(); this.choicesEl.innerHTML = ''; onSelect(c); });
      this.choicesEl.appendChild(btn);
    });
  }

  showEnding(title, message, emoji='🎉') {
    this.gameEnded = true; setAutoMode(false); setSkipMode(false);
    const newPanel = this.dialogPanel.cloneNode(true); this.dialogPanel.parentNode.replaceChild(newPanel, this.dialogPanel); this.dialogPanel = newPanel;
    newPanel.innerHTML = `<div style="text-align:center;padding:20px;"><div style="font-size:48px;">${emoji}</div><h2 style="color:var(--accent)">${title}</h2><p style="white-space:pre-line">${message}</p><button class="choice-btn" onclick="location.reload()">重新开始</button></div>`;
  }

  addLog(speaker, text) {
    const logContent = document.getElementById('logContent'); if (!logContent) return;
    const entry = document.createElement('div'); entry.className = 'log-entry'; entry.dataset.nodeId = gameState.currentNodeId;
    entry.innerHTML = `<span class="speaker">${speaker||'旁白'}</span>: ${text}`;
    entry.addEventListener('click', () => { if (gameState.currentNodeId !== entry.dataset.nodeId) { jumpToNode(entry.dataset.nodeId); closePanel('logPanel'); } });
    logContent.appendChild(entry); logContent.scrollTop = logContent.scrollHeight;
  }
}

class Interpreter {
  constructor(state, ui) { this.state = state; this.ui = ui; this.script = {}; this._bgmSource = null; }
  loadScript(s) { this.script = s; }
  async start(nodeId='start') { this.state.currentNodeId = nodeId; await this.executeNode(nodeId); }
  async executeNode(nodeId, isRollback = false) {
    if (this.ui.gameEnded) return;
    const node = this.script[nodeId]; if (!node) return;
    this.state.currentNodeId = nodeId;

    if (!isRollback) {
      node.effects?.forEach(e => { if (e.type==='add') this.state.addVar(e.target,e.value); else if (e.type==='set') this.state.setVar(e.target,e.value); });
      if (node.type === 'dialogue' || node.type === 'branch') historyStack.push(nodeId);
      if (node.bgm) { if (this._bgmSource) this._bgmSource.stop(); this._bgmSource = await playAudio(node.bgm, true, 'bgm'); }
      if (node.sfx) playAudio(node.sfx, false, 'sfx');
      if (node.effect) applySceneEffect(node.effect);
      if (node.type === 'dialogue') this.ui.addLog(node.speaker, node.text);
      this.state.save(0);
    }

    if (node.background !== undefined) { await this.ui.setBackground(node.background); this.state.sceneState.background = node.background; }
    if (node.sprites) { this.ui.clearAllSprites(); for (const s of node.sprites) await this.ui.showCharacter(s.char, s.exp, s.pos||'center'); this.state.sceneState.sprites = node.sprites; }
    if (node.filter !== undefined) { this.state.filter = node.filter; syncFXUI(node.filter, this.state.lighting); }
    if (node.lighting) { this.state.lighting = { ...this.state.lighting, ...node.lighting }; syncFXUI(this.state.filter, this.state.lighting); }

    switch (node.type) {
      case 'dialogue': this.ui.showDialogue(node.speaker, node.text, () => this.goNext(node.nextNodeId)); break;
      case 'branch': const choices = node.choices.filter(c => !c.condition || this.evaluateCondition(c.condition)); if (choices.length===0) { this.goNext(node.nextNodeId); return; } this.ui.showChoices(choices, chosen => { chosen.effects?.forEach(e => { if (e.type==='add') this.state.addVar(e.target,e.value); else if (e.type==='set') this.state.setVar(e.target,e.value); }); this.goNext(chosen.nextNodeId); }); break;
      case 'ending': this.ui.showEnding(node.title, node.text, node.emoji); break;
    }
    updateScriptHighlight();
  }
  goNext(nextId) { if (nextId) this.executeNode(nextId); }
  evaluateCondition(condStr) {
    const match = condStr.match(/^(\w+)\s*(>=|<=|>|<|==)\s*(\d+)$/);
    if (!match) return true;
    const [, varName, op, val] = match;
    const cur = this.state.getVar(varName) || 0; const target = parseInt(val);
    switch (op) { case '>=': return cur >= target; case '<=': return cur <= target; case '>': return cur > target; case '<': return cur < target; case '==': return cur == target; }
  }
}

function applySceneEffect(effect) {
  if (!effect) return;
  const sceneEl = document.getElementById('scene');
  if (effect === 'shake') { sceneEl.classList.add('shake'); setTimeout(() => sceneEl.classList.remove('shake'), 400); }
  else if (effect === 'flash') { sceneEl.classList.add('flash'); setTimeout(() => sceneEl.classList.remove('flash'), 200); }
}

// 剧本对照表
function buildScriptTable() {
  const content = document.getElementById('scriptContent'); if (!content || !interpreter) return;
  const nodes = interpreter.script; let html = '';
  for (const [id, node] of Object.entries(nodes)) {
    const type = node.type || 'unknown'; const speaker = node.speaker || (type === 'branch' ? '分支' : '');
    const text = node.text ? node.text.substring(0,20) : (type === 'branch' ? `${node.choices?.length||0}选项` : '');
    html += `<div class="script-entry" data-node-id="${id}"><span style="background:rgba(255,255,255,0.2);padding:2px 6px;border-radius:4px;font-size:11px;">${type}</span><span style="flex:1;">${id}: ${speaker} - ${text}${text.length>=20?'...':''}</span></div>`;
  }
  content.innerHTML = html;
  content.querySelectorAll('.script-entry').forEach(entry => entry.addEventListener('click', () => { const nid = entry.dataset.nodeId; if (nid && gameState.currentNodeId !== nid) { jumpToNode(nid); closePanel('scriptPanel'); } }));
  updateScriptHighlight();
}
function updateScriptHighlight() { document.querySelectorAll('.script-entry').forEach(e => e.classList.toggle('active', e.dataset.nodeId === gameState?.currentNodeId)); }

// 存档面板
function showSavePanel() {
  openPanel('savePanel');
  const slotList = document.getElementById('slotList'); if (!slotList) return; slotList.innerHTML = '';
  for (let i=0;i<3;i++) {
    const saveData = localStorage.getItem(`gal_save_${i}`); let thumb='', info='空';
    if (saveData) { const data = JSON.parse(saveData); thumb = data.thumbnail ? `<img src="${data.thumbnail}">` : ''; info = data.timestamp ? new Date(data.timestamp).toLocaleString() : '未知'; }
    const div = document.createElement('div'); div.className='save-slot';
    div.innerHTML = `${thumb}<div class="slot-info"><div>槽位${i}</div><div style="font-size:12px;opacity:0.7;">${info}</div></div>`;
    const saveBtn = document.createElement('button'); saveBtn.textContent='保存'; saveBtn.addEventListener('click', () => { gameState.save(i); closePanel('savePanel'); });
    const loadBtn = document.createElement('button'); loadBtn.textContent='读取'; loadBtn.addEventListener('click', async () => { if (gameState.load(i)) { await restoreScene(); closePanel('savePanel'); } else alert('无存档'); });
    div.appendChild(saveBtn); div.appendChild(loadBtn); slotList.appendChild(div);
  }
}
async function restoreScene() {
  uiManager.gameEnded = false; const s = gameState;
  uiManager.clearAllSprites(); await uiManager.setBackground(s.sceneState.background);
  if (s.sceneState.sprites) for (const sp of s.sceneState.sprites) await uiManager.showCharacter(sp.char, sp.exp, sp.pos);
  syncFXUI(s.filter, s.lighting);
  document.getElementById('speaker').textContent=''; document.getElementById('text').textContent=''; document.getElementById('choices').innerHTML='';
  await interpreter.executeNode(s.currentNodeId);
}

