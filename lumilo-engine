// 音频系统
const audioCtx = new (window.AudioContext || window.webkitAudioContext)();
const bgmGain = audioCtx.createGain(); bgmGain.connect(audioCtx.destination);
const sfxGain = audioCtx.createGain(); sfxGain.connect(audioCtx.destination);
async function playAudio(audioId, loop = false, type = 'sfx') {
  const audioData = await getFromStore('audios', audioId);
  if (!audioData) return;
  try {
    const arrayBuffer = await fetch(audioData.data).then(r => r.arrayBuffer());
    const audioBuffer = await audioCtx.decodeAudioData(arrayBuffer);
    const source = audioCtx.createBufferSource();
    source.buffer = audioBuffer;
    source.loop = loop;
    source.connect(type === 'bgm' ? bgmGain : sfxGain);
    source.start(0);
    return source;
  } catch(e) { console.error('音频播放失败:', e); }
}
